{
  "name": "kelionai-v2",
  "version": "2.5.1",
  "description": "KelionAI \u2014 Asistent AI accesibil cu avatari 3D",
  "main": "server/index.js",
  "scripts": {
    "dev": "node server/index.js",
    "start": "node scripts/railway-sync-env.js && node server/index.js",
    "build": "node -e \"const fs=require('fs'); const f='app/index.html'; if(!fs.existsSync(f)){console.error('BUILD FAIL: '+f+' not found');process.exit(1)}\"",
    "gate": "node -e \"const fs=require('fs'); const ok=fs.existsSync('server/index.js')&&fs.existsSync('app/index.html')&&fs.existsSync('server/brain.js'); if(!ok){console.error('GATE FAIL: missing critical files');process.exit(1)} console.log('Gate: all critical files present')\"",
    "smoke": "node scripts/smoke.js",
    "security": "npm audit --audit-level=high",
    "setup": "bash scripts/setup-env.sh",
    "setup:full": "bash scripts/setup-full.sh",
    "setup:db": "bash scripts/setup-db.sh",
    "deploy": "bash scripts/deploy.sh",
    "health": "bash scripts/health-check.sh",
    "railway:setup": "node scripts/railway-setup.js",
    "railway:vars": "bash scripts/railway-env.sh",
    "setup:secrets": "bash scripts/setup-secrets.sh",
    "check:deploy": "node scripts/check-deploy-readiness.js",
    "deploy:all": "node scripts/deploy-all.js",
    "format": "prettier --write .",
    "sync-env": "node scripts/railway-sync-env.js"
  },
  "dependencies": {
    "@capacitor/android": "8.2.0",
    "@capacitor/app": "8.0.1",
    "@capacitor/browser": "8.0.2",
    "@capacitor/camera": "8.0.2",
    "@capacitor/cli": "8.2.0",
    "@capacitor/core": "8.2.0",
    "@capacitor/haptics": "8.0.1",
    "@capacitor/ios": "8.2.0",
    "@capacitor/keyboard": "8.0.1",
    "@capacitor/push-notifications": "8.0.2",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@sentry/node": "^8.40.0",
    "@supabase/supabase-js": "^2.45.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "7.3.1",
    "form-data": "4.0.5",
    "helmet": "^7.1.0",
    "lip-sync-engine": "^1.0.0",
    "morgan": "1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "8.0.4",
    "openai": "^6.32.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.0",
    "socket.io": "^4.8.0",
    "stripe": "21.0.1",
    "winston": "3.19.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "prettier": "3.8.1"
  },
  "license": "MIT",
  "author": ""
}