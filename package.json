{
  "name": "kelionai-v2",
  "version": "2.5.0",
  "description": "KelionAI — Asistent AI accesibil cu avatari 3D",
  "main": "server/index.js",
  "scripts": {
    "prestart": "node scripts/pre-start-audit.js",
    "dev": "node server/index.js",
    "start": "node scripts/pre-start-audit.js && node server/index.js",
    "gate": "node scripts/gate.js",
    "lint": "npx eslint server/",
    "typecheck": "node -e \"/* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* /* console.log('typecheck: N/A (JS-only project) (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */ (removed) */')\"",
    "build": "node -e \"const fs=require('fs'); const f='app/index.html'; if(!fs.existsSync(f)){console.error('BUILD FAIL: '+f+' not found');process.exit(1)}\"",
    "smoke": "node scripts/smoke.js",
    "security": "npm audit --audit-level=high",
    "e2e": "npx playwright test tests/e2e-full.spec.js --project=chromium",
    "test": "npx playwright test --project=chromium",
    "test:all": "npx playwright test",
    "test:e2e": "npx playwright test tests/e2e-full.spec.js --project=chromium",
    "test:unit": "jest --forceExit",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit",
    "test:report": "npx playwright show-report",
    "setup": "bash scripts/setup-env.sh",
    "setup:full": "bash scripts/setup-full.sh",
    "setup:db": "bash scripts/setup-db.sh",
    "deploy": "bash scripts/deploy.sh",
    "health": "bash scripts/health-check.sh",
    "railway:setup": "node scripts/railway-setup.js",
    "railway:vars": "bash scripts/railway-env.sh",
    "setup:secrets": "bash scripts/setup-secrets.sh",
    "check:deploy": "node scripts/check-deploy-readiness.js",
    "deploy:all": "node scripts/deploy-all.js",
    "format": "prettier --write ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/node_modules/**",
      "!server/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "clover"
    ]
  },
  "dependencies": {
    "@sentry/node": "^8.40.0",
    "@supabase/supabase-js": "^2.45.0",
    "ccxt": "^4.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eslint": "^9.17.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "lip-sync-engine": "^1.0.0",
    "mammoth": "^1.8.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.11",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.0",
    "puppeteer": "24.15.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.0",
    "stripe": "^17.4.0",
    "three": "^0.161.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "license": "MIT",
  "author": ""
}
