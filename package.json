{
    "name": "kelionai-v2",
    "version": "2.5.0",
    "description": "KelionAI — Asistent AI accesibil cu avatari 3D",
    "main": "server/index.js",
    "scripts": {
        "prestart": "node scripts/pre-start-audit.js",
        "dev": "node server/index.js",
        "start": "node scripts/pre-start-audit.js && node server/index.js",
        "gate": "node scripts/gate.js",
        "lint": "npx eslint server/",
        "typecheck": "node -e \"console.log('typecheck: N/A (JS-only project)')\"",
        "build": "node -e \"const fs=require('fs'); const f='app/index.html'; if(!fs.existsSync(f)){console.error('BUILD FAIL: '+f+' not found');process.exit(1)} console.log('Build OK: static assets validated')\"",
        "smoke": "node scripts/smoke.js",
        "security": "npm audit --audit-level=high",
        "e2e": "npx playwright test tests/e2e-full.spec.js --project=chromium",
        "test": "npx playwright test --project=chromium",
        "test:all": "npx playwright test",
        "test:e2e": "npx playwright test tests/e2e-full.spec.js --project=chromium",
        "test:unit": "jest --forceExit",
        "test:coverage": "jest --coverage",
        "test:ci": "jest --coverage --ci --forceExit",
        "test:report": "npx playwright show-report",
        "setup": "bash scripts/setup-env.sh",
        "setup:full": "bash scripts/setup-full.sh",
        "setup:db": "bash scripts/setup-db.sh",
        "deploy": "bash scripts/deploy.sh",
        "health": "bash scripts/health-check.sh",
        "railway:setup": "node scripts/railway-setup.js",
        "railway:vars": "bash scripts/railway-env.sh",
        "setup:secrets": "bash scripts/setup-secrets.sh",
        "check:deploy": "node scripts/check-deploy-readiness.js",
        "deploy:all": "node scripts/deploy-all.js"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/__tests__/**/*.test.js"
        ],
        "collectCoverage": true,
        "collectCoverageFrom": [
            "server/**/*.js",
            "!server/node_modules/**",
            "!server/**/*.test.js"
        ],
        "coverageDirectory": "coverage",
        "coverageReporters": [
            "text",
            "text-summary",
            "lcov",
            "clover"
        ]
    },
    "dependencies": {
        "@sentry/browser": "^10.40.0",
        "@sentry/node": "^10.40.0",
        "@supabase/supabase-js": "^2.98.0",
        "adm-zip": "^0.5.16",
        "archiver": "^7.0.1",
        "ccxt": "^4.4.0",
        "cors": "^2.8.5",
        "csv-parser": "^3.2.0",
        "csv-stringify": "^6.6.0",
        "docx": "^9.6.1",
        "dotenv": "^17.3.1",
        "eslint": "^10.0.3",
        "exceljs": "^4.4.0",
        "express": "^4.22.1",
        "express-rate-limit": "^8.3.1",
        "form-data": "^4.0.5",
        "franc-min": "^6.2.0",
        "helmet": "^8.1.0",
        "highlight.js": "^11.11.1",
        "js-beautify": "^1.15.4",
        "jshint": "^2.13.6",
        "lip-sync-engine": "^1.0.3",
        "mammoth": "^1.11.0",
        "marked": "^17.0.4",
        "multer": "^2.1.0",
        "node-fetch": "^2.7.0",
        "nodemailer": "^8.0.1",
        "pdf-parse": "^1.1.4",
        "pdfkit": "^0.17.2",
        "pg": "^8.18.0",
        "pino": "^10.3.1",
        "pptxgenjs": "^4.0.1",
        "prettier": "^3.8.1",
        "prom-client": "^15.1.3",
        "puppeteer": "^24.0.0",
        "sharp": "^0.34.5",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "stripe": "^20.4.0",
        "three": "^0.160.1",
        "zod": "^4.3.6"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "jest": "^30.2.0",
        "supertest": "^7.2.2"
    }
}
