# setup-env.sh creates timestamped backups of .env (e.g. .env.backup.20260226092224)
# that contain real API keys. deploy.sh calls `git add .`, which would otherwise
# stage and push these to the remote.
.env.backup.*
*.env.backup.*
server/.env.backup.*

