<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
    <string>$(CAPACITOR_DEBUG)</string>

    <!-- Bundle Info -->
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>KelionAI</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- iOS Requirements -->
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
    </array>

    <!-- Orientation - Portrait only for chat app -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Status Bar -->
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>

    <!-- Deep Linking URL Schemes -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.kelionai.app</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>kelionai</string>
            </array>
        </dict>
    </array>

    <!-- Associated Domains (App Links) -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:kelionai-v2-production.up.railway.app</string>
        <string>webcredentials:kelionai-v2-production.up.railway.app</string>
    </array>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>fetch</string>
        <string>processing</string>
        <string>audio</string>
    </array>

    <!-- Privacy Permissions -->
    <key>NSCameraUsageDescription</key>
    <string>KelionAI needs camera access for visual analysis, product scanning, and video chat.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>KelionAI needs microphone access for voice conversations with your AI assistant.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>KelionAI uses your location to provide weather, nearby places, and location-aware responses.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>KelionAI uses your location to provide weather, nearby places, and location-aware responses.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>KelionAI needs photo library access to analyze images you share in chat.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>KelionAI saves AI-generated images to your photo library.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>KelionAI uses speech recognition for voice commands and conversations.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>KelionAI uses Face ID for secure and fast authentication.</string>
    <key>NSContactsUsageDescription</key>
    <string>KelionAI can access contacts to help you share conversations easily.</string>
    <key>NSUserNotificationsUsageDescription</key>
    <string>KelionAI sends notifications for AI responses, reminders, and important updates.</string>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>kelionai-v2-production.up.railway.app</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
            <key>supabase.co</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- iTunes / App Store metadata -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

</dict>
</plist>