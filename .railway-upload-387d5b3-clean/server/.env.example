# ─────────────────────────────────────────────────────────────────────────────
# Kelion Voice – Backend API Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Obtain these from the Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The redirect URI registered in the Google Cloud Console.
# Production:
#   GOOGLE_REDIRECT_URI=https://api.kelionai.app/auth/google/callback
# Local development:
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ── Application URLs ──────────────────────────────────────────────────────────
# Production:
#   APP_BASE_URL=https://kelionai.app
#   API_BASE_URL=https://api.kelionai.app
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001

# ── Session (web clients) ─────────────────────────────────────────────────────
# Use a long random string – e.g. `openssl rand -hex 64`
SESSION_SECRET=replace-with-a-strong-random-secret

# ── JWT (mobile clients) ──────────────────────────────────────────────────────
# Use a different long random string from SESSION_SECRET
JWT_SECRET=replace-with-another-strong-random-secret
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins.
# Production:
#   CORS_ORIGINS=https://kelionai.app
CORS_ORIGINS=http://localhost:5173

# ── Cookie ────────────────────────────────────────────────────────────────────
# Production: set COOKIE_DOMAIN=kelionai.app
# Leave blank for localhost development.
COOKIE_DOMAIN=

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically if missing).
DB_PATH=./data/kelion.db

# ── Stripe (Payment Processing) ───────────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
# Leave blank to keep payment endpoints in "coming soon" mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create products + prices in the Stripe Dashboard, then
# paste the resulting price_... identifiers here. These are the ONLY source of
# truth for plan prices, currency and billing interval; never hard-code those
# in the application.
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# ── Trial / realtime session cap ──────────────────────────────────────────────
# Maximum lifetime (seconds) of any ephemeral voice-session token issued by
# /api/realtime/token, /api/realtime/trial-token and /api/realtime/gemini-token.
TRIAL_MAX_SECONDS=900

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses.
ADMIN_EMAILS=your-admin@example.com

# ── AI / Gemini (preferred) ──────────────────────────────────────────────────
# When set, Gemini is used for /api/chat and /api/tts.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
# CSV of fallback chat models attempted in order when the primary fails.
GEMINI_CHAT_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
# Leave GEMINI_LIVE_MODEL blank to iterate the fallback list only.
GEMINI_LIVE_MODEL=
GEMINI_LIVE_FALLBACKS=gemini-live-2.5-flash-preview,gemini-2.5-flash-preview-native-audio-dialog,gemini-2.0-flash-live-001
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE_KELION=Kore
GEMINI_LIVE_VOICE_KELION=Kore

# ── AI / OpenAI (fallback) ───────────────────────────────────────────────────
# Used only if GEMINI_API_KEY is not set, or for the OpenAI Realtime WebRTC flow
# which is still the default transport for /api/realtime/token.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE_KELION=ash

# ── ElevenLabs (Text-to-Speech) ──────────────────────────────────────────────
# Required for /api/tts endpoint. Obtain from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Optional: override the default multilingual voice id
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
