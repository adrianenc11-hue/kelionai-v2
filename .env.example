# ═══════════════════════════════════════════════════════════════
# KelionAI v2 — ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# Run: node validate-keys.js to test all keys
# ═══════════════════════════════════════════════════════════════

# ═══ 🔴 OBLIGATORII — fără ele serverul nu funcționează ═══

GOOGLE_AI_KEY=                  # aistudio.google.com/apikey
SUPABASE_URL=                    # supabase.com/dashboard → Settings → API
SUPABASE_ANON_KEY=               # Același loc (cheia publică "anon")
SUPABASE_SERVICE_KEY=            # Același loc (cheia "service_role" — SECRETĂ)
ELEVENLABS_API_KEY=              # elevenlabs.io/app/settings/api-keys
SESSION_SECRET=                    # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ═══ 🟡 RECOMANDATE ═══

OPENAI_API_KEY=                  # platform.openai.com/api-keys (fallback chat + Whisper)
DEEPSEEK_API_KEY=                # platform.deepseek.com/api_keys (fallback #3)
GROQ_API_KEY=                    # console.groq.com/keys (Whisper STT rapid)
DEEPGRAM_API_KEY=                # console.deepgram.com → API Keys (streaming STT sub-150ms)
CARTESIA_API_KEY=                # play.cartesia.ai → API Keys (streaming TTS sub-90ms)
STRIPE_SECRET_KEY=               # dashboard.stripe.com/apikeys (sk_live_ sau sk_test_)
STRIPE_WEBHOOK_SECRET=           # Stripe → Webhooks → Signing secret (whsec_...)
TAVILY_API_KEY=                  # app.tavily.com/home (web search)

# ═══ 🟢 OPȚIONALE ═══

PERPLEXITY_API_KEY=              # perplexity.ai/settings/api
SERPER_API_KEY=                  # serper.dev (Google results)
TOGETHER_API_KEY=                # api.together.ai/settings/api-keys (imagini FLUX)
GOOGLE_MAPS_KEY=                 # console.cloud.google.com → Maps Embed API
GOOGLE_CALENDAR_API_KEY=         # console.cloud.google.com → GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=              # Calendar ID (default: primary)
SENTRY_DSN=                      # sentry.io → Project → Client Keys (DSN)
ELEVENLABS_VOICE_KELION=         # ElevenLabs → Voices → ID (default: pNInz6obpgDQGcFmaJgB)
ELEVENLABS_VOICE_KIRA=           # ElevenLabs → Voices → ID
REFERRAL_SECRET=                   # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ═══ 📱 SOCIAL CHANNELS ═══

# WhatsApp Cloud API — set both variants (same key, code checks all)
WA_ACCESS_TOKEN=                 # Meta Business → WhatsApp API → Token
WHATSAPP_TOKEN=                  # ← SAME KEY as WA_ACCESS_TOKEN
WHATSAPP_ACCESS_TOKEN=           # ← SAME KEY as WA_ACCESS_TOKEN
WA_PHONE_NUMBER_ID=              # Meta Business → Phone Numbers → ID
WHATSAPP_PHONE_NUMBER_ID=        # ← SAME ID as WA_PHONE_NUMBER_ID
WA_VERIFY_TOKEN=                 # REQUIRED: Choose any unique string (webhook verification token — no default)
WHATSAPP_VERIFY_TOKEN=           # ← SAME TOKEN as WA_VERIFY_TOKEN
WA_APP_SECRET=                   # Meta App Secret (HMAC-SHA256 webhook signature)
MESSENGER_PAGE_TOKEN=            # Meta Developers → Page Access Token
MESSENGER_VERIFY_TOKEN=          # Choose any string
TELEGRAM_BOT_TOKEN=              # @BotFather on Telegram
FACEBOOK_PAGE_TOKEN=             # Meta Business → Page token
INSTAGRAM_TOKEN=                 # Meta Business → Instagram API

# ═══ APP CONFIG ═══

APP_URL=https://kelionai.app     # Production URL (Railway domain)
NODE_ENV=production
PORT=3000

# ═══ TRADING BOT (opțional) ═══

BINANCE_API_KEY=                 # binance.com → API Management
BINANCE_API_SECRET=              # Același loc (SECRET — fără withdrawal permissions!)
BINANCE_TESTNET=true             # 'true' pentru testnet, șterge pentru live
MAX_TRADE_AMOUNT=100             # Max $ per trade

# ═══ NEWS APIs (opțional — fallback-uri) ═══

NEWSAPI_KEY=                     # newsapi.org
GNEWS_KEY=                       # gnews.io
GUARDIAN_KEY=                    # open-platform.theguardian.com
CURRENTS_API_KEY=                # currentsapi.services
MEDIASTACK_KEY=                  # mediastack.com

# ═══ STRIPE PRICE IDs (din Stripe Dashboard → Products) ═══

STRIPE_PRO_PRICE_ID=             # Price ID pentru planul Pro (monthly)
STRIPE_PRO_ANNUAL_PRICE_ID=      # Price ID pentru planul Pro Annual — creează în Stripe Dashboard → Products → Add Price (Recurring, €99.90/year)
STRIPE_PREMIUM_PRICE_ID=         # Price ID pentru planul Premium (monthly)
STRIPE_PREMIUM_ANNUAL_PRICE_ID=  # Price ID pentru planul Premium Annual — creează în Stripe Dashboard → Products → Add Price (Recurring, €199.90/year)
ADMIN_SECRET_KEY=                # Cheie secretă pentru admin panel

# ═══ DATABASE (auto-setat de Railway dacă folosești Supabase) ═══

# DATABASE_URL=                  # Opțional — pentru migrații directe
# SUPABASE_DB_PASSWORD=          # Opțional — parolă DB directă

# ═══ MESSENGER EXTRA ═══

FB_VERIFY_TOKEN=                 # Token verificare webhook Facebook
FB_APP_SECRET=                   # Facebook App Secret (HMAC-SHA256)

# ═══ VOICE IDs (au default-uri) ═══

ELEVENLABS_VOICE_KELION=VR6AewLTigWG4xSOukaG
ELEVENLABS_VOICE_KIRA=EXAVITQu4vr4xnSDxMaL

