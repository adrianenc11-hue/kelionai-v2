# ─────────────────────────────────────────────────────────────────────────────
# Kelion Voice – Backend API Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Obtain these from the Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The redirect URI registered in the Google Cloud Console.
# Production:
#   GOOGLE_REDIRECT_URI=https://api.kelionai.app/auth/google/callback
# Local development:
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ── Application URLs ──────────────────────────────────────────────────────────
# Production:
#   APP_BASE_URL=https://kelionai.app
#   API_BASE_URL=https://api.kelionai.app
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001

# ── Session (web clients) ─────────────────────────────────────────────────────
# Use a long random string – e.g. `openssl rand -hex 64`
SESSION_SECRET=replace-with-a-strong-random-secret

# ── JWT (mobile clients) ──────────────────────────────────────────────────────
# Use a different long random string from SESSION_SECRET
JWT_SECRET=replace-with-another-strong-random-secret
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins.
# Production:
#   CORS_ORIGINS=https://kelionai.app
CORS_ORIGINS=http://localhost:5173

# ── Cookie ────────────────────────────────────────────────────────────────────
# Production: set COOKIE_DOMAIN=kelionai.app
# Leave blank for localhost development.
COOKIE_DOMAIN=

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically if missing).
DB_PATH=./data/kelion.db

# ── Stripe (Payment Processing) ───────────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
# Leave blank to keep payment endpoints in "coming soon" mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses.
ADMIN_EMAILS=your-admin@example.com

# ── AI / Google (Gemma 4) ────────────────────────────────────────────────────
# When set, Gemma 4 is used for /api/chat and /api/tts.
# Obtain from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CHAT_MODEL=gemma-4-31b-it
GOOGLE_LIVE_MODEL=gemma-4-31b-it
GOOGLE_TTS_MODEL=gemma-4-31b-it
GOOGLE_TTS_VOICE_KELION=Kore
GOOGLE_LIVE_VOICE_KELION=Kore



# ── ElevenLabs (Text-to-Speech) ──────────────────────────────────────────────
# Required for /api/tts endpoint. Obtain from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Optional: override the default multilingual voice id
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Auto-topup (Owner's saved Stripe card) ───────────────────────────────────
# When all three values below are set, the admin dashboard will, on every
# refresh of /api/admin/credits, silently charge the owner's saved card
# for AUTO_TOPUP_AMOUNT_EUR whenever an AI provider drops below
# AUTO_TOPUP_THRESHOLD. Today only ElevenLabs exposes a numeric balance
# ratio, so it is the only provider that can trigger an auto-topup.
# Cooldown prevents duplicate charges on refresh storms.
# Set up the Customer + PaymentMethod once in Stripe Dashboard:
#   https://dashboard.stripe.com/customers
OWNER_STRIPE_CUSTOMER_ID=
OWNER_STRIPE_PAYMENT_METHOD_ID=
AUTO_TOPUP_THRESHOLD=0.2
AUTO_TOPUP_AMOUNT_EUR=20
AUTO_TOPUP_CURRENCY=eur
AUTO_TOPUP_COOLDOWN_MS=86400000
AUTO_TOPUP_ENABLED=true

# ── YouTube Data API v3 (F10 — real inline video embed on stage monitor) ────
# Optional. When set, /api/youtube/search resolves free-text `show_on_monitor
# ('video', query)` calls into an embeddable videoId via the official API
# (type=video, videoEmbeddable=true), so the avatar's stage monitor plays
# the video inline instead of showing an external "open YouTube" card.
# Leave blank to fall back gracefully to the external results card.
# Obtain from https://console.cloud.google.com/apis/credentials
# (enable "YouTube Data API v3" first). Free tier: 10k units/day (~100 searches).
YOUTUBE_API_KEY=

# ── Sentry (optional error tracking) ─────────────────────────────────────────
# Obtain DSN from https://sentry.io/ (create project → Settings → Client Keys).
# Leave blank to disable Sentry and keep the existing custom reporter only.
SENTRY_DSN=
# Frontend DSN (can be the same project or a separate one).
VITE_SENTRY_DSN=

# ── Agent Mode (Kelion can act as a coding AI assistant) ───────────────────────
# Set to 1 to enable /api/agent/* routes (admin-only, rate-limited).
AGENT_ENABLED=1
# Path on disk where agent file-system ops are allowed (defaults to repo root).
AGENT_ROOT=/app
# GitHub token for PR/merge operations (needs repo + workflow scopes).
AGENT_GITHUB_TOKEN=
# Google Custom Search credentials for web search.
AGENT_GOOGLE_CX=
AGENT_GOOGLE_API_KEY=
# Railway token for deploy operations.
AGENT_RAILWAY_TOKEN=

# OpenRouter API key (primary LLM provider for chat/coder/vision).
# Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override default models without redeploying.
# MODEL_CHAT=anthropic/claude-3.5-sonnet
# MODEL_CHAT_HEAVY=anthropic/claude-3-opus-20240229

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
